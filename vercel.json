{
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/scoreboard", "destination": "/scoreboard/index.html" },
    { "source": "/templates", "destination": "/templates/index.html" },
    { "source": "/templates/:slug", "destination": "/templates/:slug/index.html" },
    { "source": "/demo", "destination": "/demo/index.html" },
    { "source": "/join", "destination": "/join/index.html" },
    { "source": "/checkout", "destination": "/checkout/index.html" },
    { "source": "/checkout/:slug", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/:rest*", "destination": "/index.html" },
    { "source": "/host", "destination": "/index.html" },
    { "source": "/event/:rest*", "destination": "/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/embed-batch",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://va.vercel-scripts.com https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.supabase.in https://generativelanguage.googleapis.com https://va.vercel-scripts.com https://vercel.live https://vitals.vercel-insights.com wss://ws.vercel.live; worker-src 'self' blob:; frame-src 'self' https://vercel.live; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" }
      ]
    },
    {
      "source": "/event/:id/embed",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *;" }
      ]
    }
  ]
}
