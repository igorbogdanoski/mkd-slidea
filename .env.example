VITE_BANK_MKD_NAME=Игор Богданоски
VITE_BANK_MKD_BANK=НЛБ Банка АД Скопје
VITE_BANK_MKD_ACCOUNT=210501596102457

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Генерирај со: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY се испраќа на клиентот (пред VITE_ е ок — тоа е јавен клуч).
# VAPID_PRIVATE_KEY е само server-side (никогаш VITE_!).
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Cron secret (за push-send и embed-batch auth)
CRON_SECRET=replace_with_a_long_random_hex_string

# Server-side (за create-order API): Resend за email notifications + admin destination
# RESEND_API_KEY: создади на https://resend.com → API Keys → Create API Key (Sending access)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=MKD Slidea <orders@slidea.mismath.net>
