# ─── Frontend (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AI_API_KEY=your_gemini_api_key

# ─── Edge functions / API (Vercel) ────────────────────────────────
# Gemini за generate.js + embeddings (gemini-embedding-001)
GEMINI_API_KEY=your_gemini_api_key
# Gemini 3.6 Flash — најнов stable flash (главен workhorse: генерирање/оценување/insights).
GEMINI_FLASH_MODEL=gemini-3.6-flash
# Gemini 3.1 Pro — најнов pro (advanced reasoning). Preview: 2-неделно деprecation notice.
GEMINI_PRO_MODEL=gemini-3.1-pro-preview
# ВНИМАНИЕ: промена на embed-моделот бара РЕ-ЕМБЕДИРАЊЕ на сите постоечки вектори
# (curriculum_chunks/polls/community_templates) — различен модел = различен векторски простор.
GEMINI_EMBED_MODEL=gemini-embedding-001

# Supabase service role (само за server-side; НЕ го изложувај клиентски)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI rate / budget
AI_DAILY_BUDGET=500

# Sprint 8.1 — RAG toggle (1 = on, 0 = off)
RAG_ENABLED=1

# Sprint 8.1.3 — Embed-batch cron auth.
# Генерирај силен случаен токен (пример: openssl rand -hex 32) и постави го
# и тука и во Vercel → Settings → Environment Variables. Vercel Cron автоматски
# ќе го испрати како Authorization: Bearer <vrednost> на /api/embed-batch.
EMBED_BATCH_SECRET=replace_with_a_long_random_hex_string

# ─── Manual Billing (PayPal + IBAN + МКД трансакциска сметка) ─────
# Овие VITE_* се изложени клиентски (на /checkout страницата). За тоа е во ред —
# тоа се јавни payment details. Не ставај private API keys овде.
VITE_BILLING_COMPANY=Игор Богданоски
VITE_BILLING_ADDRESS=ул. Кузман Јосифоски 221, 7500 Прилеп, Северна Македонија
VITE_BILLING_TAX_ID=
VITE_BILLING_EMAIL=igorbogdanoski@mismath.net
VITE_BILLING_SUPPORT=igorbogdanoski@mismath.net
VITE_BILLING_PHONE=+389 70 246 814

VITE_PAYPAL_EMAIL=igor.bogdanoski@mismath.net
VITE_PAYPAL_ME=

VITE_BANK_EUR_NAME=Igor Bogdanoski
VITE_BANK_EUR_BANK=NLB Banka AD Skopje
VITE_BANK_EUR_IBAN=MK07210501596102457
