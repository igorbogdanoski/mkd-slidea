<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>54a0f443-4a1b-40f2-892b-8a8f19293123</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>MKD Slidea</ProviderName>
  <DefaultLocale>mk-MK</DefaultLocale>
  <DisplayName DefaultValue="MKD Slidea" />
  <Description DefaultValue="Интерактивна алатка за презентации, анкети и квизови во живо." />
  <IconUrl DefaultValue="https://mkd-slidea.vercel.app/favicon.svg" />
  <HighResolutionIconUrl DefaultValue="https://mkd-slidea.vercel.app/favicon.svg" />
  <SupportUrl DefaultValue="https://mkd-slidea.vercel.app/integrations/index.html#microsoft" />
  <AppDomains>
    <AppDomain>https://mkd-slidea.vercel.app</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://mkd-slidea.vercel.app" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>
          <GetStarted>
            <Title DefaultValue="MKD Slidea" />
            <Description DefaultValue="Отворете MKD Slidea и додајте анкети, квизови и интеракција во презентацијата." />
            <LearnMoreUrl DefaultValue="https://mkd-slidea.vercel.app/integrations/index.html#microsoft" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="GroupSlidea">
                <Label DefaultValue="MKD Slidea" />
                <Control xsi:type="Button" id="BtnOpenSlidea">
                  <Label DefaultValue="Отвори MKD Slidea" />
                  <Supertip>
                    <Title DefaultValue="Отвори MKD Slidea" />
                    <Description DefaultValue="Додајте анкети и квизови во живо во презентацијата." />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://mkd-slidea.vercel.app/favicon.svg" />
        <bt:Image id="Icon.32x32" DefaultValue="https://mkd-slidea.vercel.app/favicon.svg" />
        <bt:Image id="Icon.80x80" DefaultValue="https://mkd-slidea.vercel.app/favicon.svg" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://mkd-slidea.vercel.app" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://mkd-slidea.vercel.app" />
      </bt:Urls>
    </Resources>
  </VersionOverrides>
</OfficeApp>
